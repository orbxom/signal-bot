# Required
BOT_PHONE_NUMBER=+61234567890

# Optional (with defaults)
# Note: "c " trigger has a trailing space (matches "c hello" but not "cat")
MENTION_TRIGGERS=@bot,bot:,c
CONTEXT_WINDOW_SIZE=20
SIGNAL_CLI_URL=http://signal-cli:8080
DB_PATH=./data/bot.db
SYSTEM_PROMPT=You are a helpful family assistant in a Signal group chat. Be friendly, concise, and helpful.
CLAUDE_MAX_TURNS=25
# SOURCE_ROOT=./  # Path to repo root for source code self-reading (auto-detected in dev)
# DARK_FACTORY_ENABLED=1  # Enable dark factory MCP tools (start/read autonomous sessions)
